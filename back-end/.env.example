# Copie pra `.env` (gitignored) e preencha. NUNCA commita.

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Supabase — pega no Dashboard → Settings → API
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Clerk — pega no Dashboard do Clerk → API keys
CLERK_PUBLISHABLE_KEY=pk_xxx
CLERK_SECRET_KEY=sk_xxx

# Clerk Webhook — pega no Dashboard → Webhooks → endpoint criado → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
